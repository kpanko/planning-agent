# ── API Keys (at least one LLM provider required) ──

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
TODOIST_API_KEY=...

# ── Model Selection (optional) ──
#
# If not set, the agent auto-detects based on which
# API key is available (Anthropic preferred over OpenAI).
#
# Format: provider:model-name
#
# Anthropic examples:
#   LLM_MODEL=anthropic:claude-sonnet-4-6
#   LLM_MODEL=anthropic:claude-opus-4-6
#   EXTRACTION_MODEL=anthropic:claude-haiku-4-5
#
# OpenAI examples:
#   LLM_MODEL=openai:gpt-4o
#   LLM_MODEL=openai:gpt-4.1
#   EXTRACTION_MODEL=openai:gpt-4o-mini
#   EXTRACTION_MODEL=openai:gpt-4.1-mini
#
# Google examples:
#   LLM_MODEL=google-gla:gemini-2.5-pro
#   EXTRACTION_MODEL=google-gla:gemini-2.5-flash
#
# LLM_MODEL=anthropic:claude-sonnet-4-6
# EXTRACTION_MODEL=anthropic:claude-haiku-4-5

# ── Data Directory (optional) ──
#
# Where values.md, memories.json, and conversations/
# are stored. Defaults to ~/.planning-agent/
#
# PLANNING_AGENT_DATA_DIR=/path/to/data
